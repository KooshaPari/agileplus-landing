---
import "../../styles/globals.css";

// Tier-3 microfrontend: /otel — observability iframe.
// Spec: phenotype-infra/docs/governance/path-microfrontends-tier3.md
//
// Embed the externally hosted Phenotype observability UI.
// PHENO_OTLP_UI_URL is canonical; PHENO_OBSERVABILITY_UI_URL is accepted as an alias
// so backend and landing deploys can converge without another code change.
// We do NOT silently render an empty iframe.
const observabilityEnvCandidates = [
  ["PHENO_OTLP_UI_URL", import.meta.env.PHENO_OTLP_UI_URL ?? process.env.PHENO_OTLP_UI_URL],
  [
    "PHENO_OBSERVABILITY_UI_URL",
    import.meta.env.PHENO_OBSERVABILITY_UI_URL ?? process.env.PHENO_OBSERVABILITY_UI_URL,
  ],
] as const;

const configuredEnv = observabilityEnvCandidates.find(
  ([, value]) => typeof value === "string" && value.trim().length > 0,
);
const configuredEnvKey = configuredEnv?.[0] ?? "PHENO_OTLP_UI_URL";
const rawOtelUrl = configuredEnv?.[1]?.trim() ?? null;
const otelUrl = rawOtelUrl && /^https?:\/\//.test(rawOtelUrl) ? rawOtelUrl : null;
const invalidOtelUrl = rawOtelUrl && !otelUrl ? rawOtelUrl : null;
const otelPolicyCheck = otelUrl ? await checkFramePolicy(otelUrl) : null;
const iframeBlocked = Boolean(otelPolicyCheck && !otelPolicyCheck.allowed);
const iframeBlockedReason = otelPolicyCheck?.reason ?? null;
const otelRunbookPath = "docs/tasks/otel-observability-backend.md";
const otelRunbookUrl = `https://github.com/KooshaPari/agileplus-landing/blob/main/${otelRunbookPath}`;

type FramePolicyCheck = {
  allowed: boolean;
  reason: string | null;
  policy: string | null;
};

async function checkFramePolicy(url: string): Promise<FramePolicyCheck | null> {
  try {
    const response = await fetch(url, {
      method: "GET",
      redirect: "follow",
    });

    const csp = response.headers.get("content-security-policy");
    if (csp && /frame-ancestors\s+'none'/i.test(csp)) {
      return {
        allowed: false,
        reason: "the configured UI explicitly forbids framing via Content-Security-Policy",
        policy: csp,
      };
    }

    const xFrameOptions = response.headers.get("x-frame-options");
    if (xFrameOptions && /deny|sameorigin/i.test(xFrameOptions)) {
      return {
        allowed: false,
        reason: "the configured UI blocks framing via X-Frame-Options",
        policy: xFrameOptions,
      };
    }

    return {
      allowed: true,
      reason: null,
      policy: csp ?? xFrameOptions,
    };
  } catch (error) {
    console.warn(
      `[otel] frame policy probe failed for ${url}: ${(error as Error).message}; falling back to iframe render`,
    );
    return null;
  }
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OTel · AgilePlus</title>
    <meta name="description" content="Embedded observability backend (traces, metrics, logs)." />
  </head>
  <body class="min-h-screen">
    <main class="max-w-7xl mx-auto px-6 py-8">
      <nav class="mono text-xs text-[var(--muted)] mb-4">
        <a href="/" class="hover:text-[var(--accent)]">agileplus</a>
        <span class="mx-1">/</span>
        <span>otel</span>
      </nav>

      <header class="mb-6 flex flex-wrap items-baseline justify-between gap-3">
        <div>
          <h1 class="text-3xl font-bold">Observability</h1>
          <p class="text-[var(--muted)] text-sm">
            Embedded OTel UI (traces, metrics, logs) from the Phenotype observability backend.
          </p>
        </div>
        {otelUrl && (
          <a href={otelUrl} target="_blank" rel="noopener"
             class="mono text-xs px-3 py-1.5 rounded border hover:text-[var(--accent)] hover:border-[var(--accent)] transition"
             style="border-color: var(--border);">
            open in new tab →
          </a>
        )}
      </header>

      {otelUrl && !iframeBlocked ? (
        <div class="otel-frame-wrap">
          <iframe
            src={otelUrl}
            title="OTel observability UI"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
            class="otel-frame"
          ></iframe>
        </div>
      ) : (
        <div class="otel-degraded">
          <h2 class="mono text-sm uppercase tracking-wider mb-3">
            {invalidOtelUrl ? "Backend URL invalid" : iframeBlocked ? "Backend not embeddable" : "Backend not configured"}
          </h2>
          {invalidOtelUrl ? (
            <p class="mb-3">
              <code>{configuredEnvKey}</code> is set, but it is not an absolute HTTP(S) URL:
              <code>{invalidOtelUrl}</code>.
            </p>
          ) : iframeBlocked ? (
            <p class="mb-3">
              The configured observability UI cannot be embedded in an iframe because
              {iframeBlockedReason ? ` ${iframeBlockedReason}.` : " its response blocks framing."}
            </p>
          ) : (
            <p class="mb-3">
              The <code>PHENO_OTLP_UI_URL</code> environment variable is not set
              for this Vercel deployment. Tier-3 <code>/otel</code> requires the
              externally hosted PhenoObservability UI to embed.
            </p>
          )}
          <details class="mt-4">
            <summary class="cursor-pointer text-[var(--accent)] mono text-sm">how to fix</summary>
            <ol class="mt-3 ml-5 text-sm space-y-2 list-decimal text-[var(--muted)]">
              <li>Deploy PhenoObservability with a public Grafana/Tempo UI URL.</li>
              <li>
                In the Vercel dashboard for <code>agileplus-landing</code>, set
                <code>PHENO_OTLP_UI_URL</code> to that URL.
              </li>
              <li>
                Use a UI that explicitly permits framing. Arize public app pages and other
                hosts that send <code>frame-ancestors 'none'</code> or
                <code>X-Frame-Options</code> deny/sameorigin will not work here.
              </li>
              <li>Redeploy. The iframe will pick up the URL on the next build.</li>
            </ol>
            <p class="mt-3 text-sm text-[var(--muted)]">
              Long-term task and acceptance criteria:
              <a
                href={otelRunbookUrl}
                target="_blank"
                rel="noreferrer"
                class="underline hover:text-[var(--accent)]"
              >
                OTel backend runbook
              </a>.
            </p>
          </details>
        </div>
      )}

      <footer class="mt-10 pt-6 border-t text-xs text-[var(--muted)] mono" style="border-color: var(--border);">
        Spec: <a href="https://github.com/KooshaPari/phenotype-infra/blob/main/docs/governance/path-microfrontends-tier3.md" class="underline hover:text-[var(--accent)]">path-microfrontends-tier3.md</a>
      </footer>
    </main>

    <style is:global>
      .otel-frame-wrap {
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        overflow: hidden;
        background: var(--card);
        height: calc(100vh - 240px);
        min-height: 500px;
      }
      .otel-frame {
        width: 100%;
        height: 100%;
        border: 0;
        display: block;
      }
      .otel-degraded {
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        background: var(--card);
        padding: 1.5rem 1.75rem;
        border-radius: 0.75rem;
        max-width: 720px;
      }
      .otel-degraded code {
        background: rgba(0,0,0,0.25);
        padding: 0.1rem 0.35rem;
        border-radius: 0.2rem;
        font-size: 0.9em;
      }
    </style>
  </body>
</html>
